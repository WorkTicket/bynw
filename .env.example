# Copy to .env.local for local dev and set the same values as
# Cloudflare Workers secrets for production.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Search Console — verification code from GSC → Settings → Ownership verification
# Optional: leave empty if you verify via DNS or Google Analytics instead
NEXT_PUBLIC_GSC_VERIFICATION=

# Google Analytics — measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Meta / Facebook Pixel — pixel ID (format: 000000000000000)
NEXT_PUBLIC_FB_PIXEL_ID=

# Mailchimp — saves name/email from the free gift form
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
