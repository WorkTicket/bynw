# Copy to .env.local for local dev and set the same values as
# Cloudflare Workers secrets for production.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mailchimp — saves name/email from the free gift form
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=

# Contact form → bynw808@gmail.com (see scripts/gmail-contact-webhook.gs)
# GMAIL_CONTACT_WEBHOOK_URL=
# GMAIL_CONTACT_WEBHOOK_TOKEN=
CONTACT_EMAIL=bynw808@gmail.com

# Optional fallback for contact form (if Gmail webhook is not set)
# RESEND_API_KEY=
