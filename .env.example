# Copy to .env.local for local dev and set the same values as
# Cloudflare Pages environment variables / wrangler secrets for production.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mailchimp — https://mailchimp.com/help/about-api-keys/
# API key ends with a datacenter suffix like -us12 (used automatically)
MAILCHIMP_API_KEY=
# Audience ID — Mailchimp → Audience → Settings → Audience name and defaults
MAILCHIMP_AUDIENCE_ID=

# Optional: contact form email notifications (Resend or another provider)
# RESEND_API_KEY=
CONTACT_EMAIL=bynw808@gmail.com
